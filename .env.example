# Isaac Savefile Analyzer - Environment Variables Example
# Copiez ce fichier en .env et remplissez les valeurs

# GitHub Pages Configuration
VITE_GITHUB_PAGES_REPO=isaac-analyzer
VITE_GITHUB_USERNAME=your-username

# Feature Flags (pour développement)
VITE_ENABLE_DEBUG=false
VITE_MAX_FILE_SIZE=10485760  # 10MB en bytes

# API Configuration (pour futures extensions)
VITE_API_URL=https://api.example.com
VITE_API_KEY=

# Analytics (optionnel)
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=
